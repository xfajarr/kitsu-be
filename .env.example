# Server
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kitsu

# TonCenter API
TONCENTER_API_KEY=your_toncenter_api_key
TONCENTER_V2_URL=https://testnet.toncenter.com/api/v2
TONCENTER_V3_URL=https://testnet.toncenter.com/api/v3
TONCENTER_V2_URL_TESTNET=https://testnet.toncenter.com/api/v2
TONCENTER_V3_URL_TESTNET=https://testnet.toncenter.com/api/v3
TONCENTER_JSONRPC_URL_TESTNET=https://testnet.toncenter.com/api/v2/jsonRPC
TONCENTER_V2_URL_MAINNET=https://toncenter.com/api/v2
TONCENTER_V3_URL_MAINNET=https://toncenter.com/api/v3
TONCENTER_JSONRPC_URL_MAINNET=https://toncenter.com/api/v2/jsonRPC

# Heurist AI
HEURIST_API_KEY=your_heurist_api_key
HEURIST_BASE_URL=https://api.heurist.ai/v1

# JWT
JWT_SECRET=your_super_secret_jwt_key

# Ston.fi
STONFI_API_URL=https://api.ston.fi
DEFAULT_TON_NETWORK=testnet

# Optional dual-network STON.fi / vault addresses
GOAL_FACTORY_ADDRESS_TESTNET=
GOAL_FACTORY_ADDRESS_MAINNET=
TONSTAKERS_POOL_ADDRESS_TESTNET=
TONSTAKERS_POOL_ADDRESS_MAINNET=
STONFI_ROUTER_ADDRESS_TESTNET=
STONFI_ROUTER_ADDRESS_MAINNET=
STONFI_PTON_MASTER_TESTNET=
STONFI_PTON_MASTER_MAINNET=
STONFI_OTHER_TOKEN_MINTER_TESTNET=
STONFI_OTHER_TOKEN_MINTER_MAINNET=
STONFI_LP_WALLET_TESTNET=
STONFI_LP_WALLET_MAINNET=
TONAPI_BASE_URL_TESTNET=https://testnet.tonapi.io/v2
TONAPI_BASE_URL_MAINNET=https://tonapi.io/v2
TONAPI_API_KEY_TESTNET=
TONAPI_API_KEY_MAINNET=

# On-chain targets (required for deposit/join transaction payloads in production)
DEN_VAULT_ADDRESS=
GOAL_VAULT_ADDRESS=
VAULT_ADDRESS=

# Pricing (optional override; default uses CoinGecko public simple/price)
# COINGECKO_SIMPLE_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=the-open-network,tether&vs_currencies=usd&include_24hr_change=true
